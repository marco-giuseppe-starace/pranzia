# Template per l'ambiente di produzione. Copiare in .env sul server e
# compilare i placeholder (CAMBIA-QUESTO) prima del deploy. Vedi
# docs/deploy.md per la checklist completa.

APP_NAME=Pranzia
APP_ENV=production
APP_KEY=
# IMPORTANTE: sempre false in produzione, non deve mai esporre stack trace.
APP_DEBUG=false
APP_URL=https://pranzia.it

APP_LOCALE=it
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error

DB_CONNECTION=mysql
DB_HOST=CAMBIA-QUESTO
DB_PORT=3306
DB_DATABASE=pranzia
DB_USERNAME=CAMBIA-QUESTO
DB_PASSWORD=CAMBIA-QUESTO

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@pranzia.it"
MAIL_FROM_NAME="${APP_NAME}"

VITE_APP_NAME="${APP_NAME}"

# Chiave API Claude reale: mai committata, mai esposta al frontend.
ANTHROPIC_API_KEY=CAMBIA-QUESTO
ANTHROPIC_MODEL_RECOMMEND=claude-sonnet-4-6
ANTHROPIC_MODEL_ASK=claude-haiku-4-5
